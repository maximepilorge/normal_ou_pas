# --- Fichiers de configuration R et RStudio ---
# Cache et fichiers temporaires spécifiques à l'utilisateur
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# --- Fichiers spécifiques au projet ---

# Fichier de variables d'environnement
.Renviron

# Caches de données locaux — la source de vérité est la BDD PostgreSQL
# On ignore le contenu mais on garde le dossier (via .gitkeep) pour que
# `COPY data data` du Dockerfile fonctionne lors du build Render.
data/*
!data/.gitkeep
# Exception : données de RÉFÉRENCE consommées par le pipeline (pas un cache),
# qui doivent être versionnées (seuils canicule officiels Météo-France).
!data/seuils_canicule_departements.csv

# Cartes de contrôle HTML générées par les scripts utils/ (artefacts QA)
carte_controle_*.html

# Fichiers temporaires R
.RDataTmp

# Configuration locale Claude Code
/.claude/

# Scripts d'analyse exploratoire station Bron (hors app)
utils/extraire_station_bron.R
utils/generer_excel_bron.py